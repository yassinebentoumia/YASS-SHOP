import { storage, uid } from './storage';
import { seedProducts, seedUsers } from '../data/seed';

const API_BASE = '/api';
let apiMode: 'unknown' | 'remote' | 'local' = 'unknown';

function ensureLocalSeeds() {
  if (storage.getProducts().length === 0) storage.setProducts(seedProducts);
  if (storage.getUsers().length === 0) storage.setUsers(seedUsers);
}

async function tryRemote(endpoint: string, options: RequestInit = {}) {
  const res = await fetch(`${API_BASE}${endpoint}`, {
    headers: { 'Content-Type': 'application/json' },
    ...options,
  });

  const contentType = res.headers.get('content-type') || '';
  if (!res.ok || !contentType.includes('application/json')) {
    throw new Error(`Remote API unavailable for ${endpoint}`);
  }

  return res.json();
}

async function request(endpoint: string, options: RequestInit = {}) {
  if (apiMode !== 'local') {
    try {
      const data = await tryRemote(endpoint, options);
      apiMode = 'remote';
      return data;
    } catch {
      apiMode = 'local';
    }
  }

  ensureLocalSeeds();
  return localRequest(endpoint, options);
}

function localRequest(endpoint: string, options: RequestInit = {}) {
  const method = (options.method || 'GET').toUpperCase();
  const body = options.body ? JSON.parse(String(options.body)) : undefined;

  // products
  if (endpoint === '/products' && method === 'GET') return Promise.resolve(storage.getProducts());
  if (endpoint === '/products' && method === 'POST') {
    const list = storage.getProducts();
    const item = { ...body, id: uid() };
    storage.setProducts([item, ...list]);
    return Promise.resolve(item);
  }
  if (endpoint.startsWith('/products/') && method === 'PUT') {
    const id = endpoint.split('/').pop()!;
    const list = storage.getProducts();
    const item = { ...body, id };
    storage.setProducts(list.map((x) => (x.id === id ? item : x)));
    return Promise.resolve(item);
  }
  if (endpoint.startsWith('/products/') && method === 'DELETE') {
    const id = endpoint.split('/').pop()!;
    storage.setProducts(storage.getProducts().filter((x) => x.id !== id));
    return Promise.resolve({ success: true });
  }

  // users
  if (endpoint === '/users' && method === 'GET') return Promise.resolve(storage.getUsers());
  if (endpoint === '/users' && method === 'POST') {
    const list = storage.getUsers();
    if (list.some((u) => u.email.toLowerCase() === body.email.toLowerCase())) {
      return Promise.resolve({ error: 'Email already exists' });
    }
    const item = { ...body, id: uid(), role: 'user', balance: 0, createdAt: Date.now() };
    storage.setUsers([...list, item]);
    return Promise.resolve(item);
  }
  if (endpoint.startsWith('/users/') && method === 'PUT') {
    const id = endpoint.split('/').pop()!;
    const list = storage.getUsers();
    const current = list.find((u) => u.id === id);
    const item = { ...current, ...body, id };
    storage.setUsers(list.map((x) => (x.id === id ? item : x)));
    return Promise.resolve(item);
  }

  // auth
  if (endpoint === '/auth/login' && method === 'POST') {
    const found = storage
      .getUsers()
      .find((u) => u.email.toLowerCase() === body.email.toLowerCase() && u.password === body.password);
    return Promise.resolve(found || { error: 'Invalid credentials' });
  }

  // orders
  if (endpoint.startsWith('/orders') && method === 'GET') {
    const query = endpoint.split('?')[1];
    const userId = query ? new URLSearchParams(query).get('userId') : null;
    const list = storage.getOrders();
    return Promise.resolve(userId ? list.filter((x) => x.userId === userId) : list);
  }
  if (endpoint === '/orders' && method === 'POST') {
    const list = storage.getOrders();
    const item = { ...body, id: uid(), createdAt: Date.now() };
    storage.setOrders([item, ...list]);
    return Promise.resolve(item);
  }
  if (endpoint.startsWith('/orders/') && method === 'PUT') {
    const id = endpoint.split('/').pop()!;
    const list = storage.getOrders();
    const current = list.find((o) => o.id === id);
    const item = { ...current, ...body, id };
    storage.setOrders(list.map((x) => (x.id === id ? item : x)));
    return Promise.resolve(item);
  }

  // rooms
  if (endpoint.startsWith('/rooms') && method === 'GET') {
    const query = endpoint.split('?')[1];
    const userId = query ? new URLSearchParams(query).get('userId') : null;
    const list = storage.getRooms();
    return Promise.resolve(userId ? list.filter((x) => x.userId === userId) : list);
  }
  if (endpoint === '/rooms' && method === 'POST') {
    const list = storage.getRooms();
    const item = { ...body, id: uid(), openedAt: Date.now() };
    storage.setRooms([item, ...list]);
    return Promise.resolve(item);
  }
  if (endpoint.startsWith('/rooms/') && method === 'PUT') {
    const id = endpoint.split('/').pop()!;
    const list = storage.getRooms();
    const current = list.find((r) => r.id === id);
    const item = { ...current, ...body, id };
    storage.setRooms(list.map((x) => (x.id === id ? item : x)));
    return Promise.resolve(item);
  }

  // messages
  if (endpoint.startsWith('/messages') && method === 'GET') {
    const query = endpoint.split('?')[1];
    const roomId = query ? new URLSearchParams(query).get('roomId') : null;
    const list = storage.getMessages();
    const filtered = roomId ? list.filter((x) => x.roomId === roomId) : list;
    return Promise.resolve(filtered.sort((a, b) => a.timestamp - b.timestamp));
  }
  if (endpoint === '/messages' && method === 'POST') {
    const list = storage.getMessages();
    const item = { ...body, id: uid(), timestamp: Date.now(), read: false };
    storage.setMessages([...list, item]);
    return Promise.resolve(item);
  }

  // transactions
  if (endpoint.startsWith('/transactions') && method === 'GET') {
    const query = endpoint.split('?')[1];
    const userId = query ? new URLSearchParams(query).get('userId') : null;
    const list = storage.getTransactions();
    return Promise.resolve(userId ? list.filter((x) => x.userId === userId) : list);
  }
  if (endpoint === '/transactions' && method === 'POST') {
    const list = storage.getTransactions();
    const item = { ...body, id: uid(), createdAt: Date.now() };
    storage.setTransactions([item, ...list]);
    return Promise.resolve(item);
  }

  // notifications
  if (endpoint.startsWith('/notifications?') && method === 'GET') {
    const query = endpoint.split('?')[1];
    const params = new URLSearchParams(query);
    const userId = params.get('userId');
    const role = params.get('role');
    const list = storage.getNotifications();
    return Promise.resolve(
      list.filter((n) => {
        if (userId) return n.userId === userId;
        if (role) return !n.userId && n.role === role;
        return true;
      })
    );
  }
  if (endpoint === '/notifications' && method === 'POST') {
    const list = storage.getNotifications();
    const item = { ...body, id: uid(), createdAt: Date.now(), read: false };
    storage.setNotifications([item, ...list]);
    return Promise.resolve(item);
  }
  if (endpoint === '/notifications/read' && method === 'PUT') {
    const userId = body?.userId;
    const list = storage.getNotifications().map((n) => {
      if (userId && n.userId === userId) return { ...n, read: true };
      if (!userId && !n.userId) return { ...n, read: true };
      return n;
    });
    storage.setNotifications(list);
    return Promise.resolve({ success: true });
  }

  return Promise.resolve({ error: `Unhandled local API route: ${method} ${endpoint}` });
}

export const api = {
  getProducts: () => request('/products'),
  addProduct: (p: any) => request('/products', { method: 'POST', body: JSON.stringify(p) }),
  updateProduct: (p: any) => request(`/products/${p.id}`, { method: 'PUT', body: JSON.stringify(p) }),
  deleteProduct: (id: string) => request(`/products/${id}`, { method: 'DELETE' }),

  getUsers: () => request('/users'),
  updateUser: (u: any) => request(`/users/${u.id}`, { method: 'PUT', body: JSON.stringify(u) }),
  register: (data: any) => request('/users', { method: 'POST', body: JSON.stringify(data) }),

  login: (email: string, password: string) => request('/auth/login', { method: 'POST', body: JSON.stringify({ email, password }) }),

  getOrders: (userId?: string) => request(userId ? `/orders?userId=${userId}` : '/orders'),
  addOrder: (o: any) => request('/orders', { method: 'POST', body: JSON.stringify(o) }),
  updateOrder: (o: any) => request(`/orders/${o.id}`, { method: 'PUT', body: JSON.stringify(o) }),

  getRooms: (userId?: string) => request(userId ? `/rooms?userId=${userId}` : '/rooms'),
  openRoom: (r: any) => request('/rooms', { method: 'POST', body: JSON.stringify(r) }),
  updateRoom: (r: any) => request(`/rooms/${r.id}`, { method: 'PUT', body: JSON.stringify(r) }),

  getMessages: (roomId?: string) => request(roomId ? `/messages?roomId=${roomId}` : '/messages'),
  sendMessage: (m: any) => request('/messages', { method: 'POST', body: JSON.stringify(m) }),

  getTransactions: (userId?: string) => request(userId ? `/transactions?userId=${userId}` : '/transactions'),
  addTransaction: (t: any) => request('/transactions', { method: 'POST', body: JSON.stringify(t) }),

  getNotifications: (userId?: string, role?: string) => {
    const params = new URLSearchParams();
    if (userId) params.set('userId', userId);
    if (role) params.set('role', role);
    return request(`/notifications?${params.toString()}`);
  },
  addNotification: (n: any) => request('/notifications', { method: 'POST', body: JSON.stringify(n) }),
  markNotificationsRead: (userId?: string) => request('/notifications/read', { method: 'PUT', body: JSON.stringify({ userId }) }),
};
